# Port, auf dem der Server laeuft
PORT=3000

# Geheimer Schluessel zum Signieren der Login-Tokens.
# WICHTIG: In Produktion durch einen langen, zufaelligen Wert ersetzen!
JWT_SECRET=bitte-einen-langen-zufaelligen-wert-eintragen

# Optional: Pfad zur SQLite-Datenbankdatei
# DB_PATH=./data.sqlite

# Maximale Anzahl an Accounts, die sich registrieren duerfen (Standard: 30)
MAX_USERS=30

# Auf "production" setzen, wenn hinter HTTPS betrieben (aktiviert secure Cookies)
# NODE_ENV=production
